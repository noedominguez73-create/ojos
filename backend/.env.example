# Anthropic API Key for Claude Vision
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Cloud credentials file path
GOOGLE_CLOUD_CREDENTIALS_PATH=/path/to/your/google-credentials.json

# Or set this environment variable directly
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-credentials.json

# TTS Settings (optional)
TTS_LANGUAGE=es-ES
TTS_VOICE_NAME=es-ES-Standard-A
TTS_SPEAKING_RATE=1.1

# Frame interval in milliseconds
FRAME_INTERVAL_MS=1500
