# OjosParaCiego - Environment Variables

# Google Gemini API Key (RECOMMENDED - get free at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Together AI API Key (fallback - https://together.ai)
TOGETHER_API_KEY=your_together_api_key_here

# Domain for SSL certificate (optional, for self-hosted)
DOMAIN=yourdomain.com
EMAIL=your@email.com
